# ============================================================
# Brigid.pro — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin (the only email address that can access /admin and grant PT roles)
ADMIN_EMAIL=you@yourdomain.com

# App URL (for redirects)
# Local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_APP_URL=https://tripleaspect.fit

# ── Nightly test agent credentials ───────────────────────
# PT account used by the automated nightly audit agent.
# Create a Supabase-invited PT user and set its role to 'pt'.
BRIGID_TEST_PT_EMAIL=test.pt@brigid.local
BRIGID_TEST_PT_PASSWORD=your-test-pt-password-here

# Client account linked to the test PT via client_agreements.
BRIGID_TEST_CLIENT_EMAIL=test.client@brigid.local
BRIGID_TEST_CLIENT_PASSWORD=your-test-client-password-here

# ── Future: Stripe ────────────────────────────────────────
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
